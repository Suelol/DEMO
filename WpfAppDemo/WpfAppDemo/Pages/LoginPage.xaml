<Page x:Class="WpfAppDemo.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppDemo.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="LoginPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Логин" TextAlignment="Center"/>
            <TextBox x:Name="TBLogin" Margin="5" Width="200"/>
            <TextBlock Text="Пароль" TextAlignment="Center"/>
            <TextBox x:Name="TBPassword" Margin="5" Width="200"/>
            <Button x:Name="BLogin" Click="BLogin_Click" Content="Войти" Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
